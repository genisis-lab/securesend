{
  "name": "securesend",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end encrypted peer-to-peer file transfer PWA. Backend is signaling-only; files never touch a server.",
  "license": "MIT",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:signal": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend",
    "test": "npm run test --workspace frontend && npm run test --workspace backend",
    "test:frontend": "npm run test --workspace frontend",
    "test:backend": "npm run test --workspace backend",
    "deploy:backend": "npm run deploy --workspace backend",
    "lint": "npm run lint --workspace frontend"
  },
  "engines": {
    "node": ">=18"
  }
}
