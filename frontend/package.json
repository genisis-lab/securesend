{
  "name": "securesend-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SecureSend PWA — end-to-end encrypted P2P file transfer in the browser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build && npm run check:pwa",
    "build:nocheck": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:pwa": "node scripts/check-pwa.mjs"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
