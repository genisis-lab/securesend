{
  "name": "securesend-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SecureSend PWA — end-to-end encrypted P2P file transfer in the browser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build && npm run check:pwa",
    "build:nocheck": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:pwa": "node scripts/check-pwa.mjs"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^2.0.5"
  }
}
