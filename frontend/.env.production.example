# Production configuration for the SecureSend PWA (Cloudflare Pages build).
# Copy this file to `frontend/.env.production` and fill in YOUR deployment URLs.
# These are NOT secrets — only the public signaling endpoint and app origin.
# (frontend/.env.production is gitignored so your real URLs stay out of git.)

# Your deployed signaling Worker (WebSocket scheme).
VITE_SIGNAL_URL=wss://securesend-signal.<your-subdomain>.workers.dev

# Public origin of your Pages deployment (used to build invite links).
VITE_APP_BASE_URL=https://<your-app>.pages.dev

# STUN server for WebRTC NAT traversal (public; safe to expose).
VITE_ICE_SERVERS=stun:stun.l.google.com:19302
