# ----------------------------------------------------------------------------
# SecureSend environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `frontend/.env.local` (for the web app) and adjust values.
# NOTE: There are NO secrets here. The signaling server holds no keys, and the
# frontend never receives any private material from the environment. The only
# configurable value is the URL of the signaling WebSocket endpoint.
# ----------------------------------------------------------------------------

# WebSocket base URL of the Cloudflare Worker signaling server.
# Local dev (wrangler dev):   ws://localhost:8787
# Production:                 wss://securesend-signal.<your-subdomain>.workers.dev
VITE_SIGNAL_URL=ws://localhost:8787

# Invite link base used when generating shareable links.
# Local dev:                  http://localhost:5173
# Production (Cloudflare Pages): https://<your-app>.pages.dev
VITE_APP_BASE_URL=http://localhost:5173

# Optional: fallback ICE / STUN servers (comma separated) used only if the
# Worker's /api/ice endpoint is unreachable. The app prefers /api/ice, which
# can mint short-lived TURN credentials (see backend TURN_* secrets below).
# For restrictive networks add a TURN server here (TURN relays encrypted
# traffic but still never sees plaintext — E2EE is preserved).
# Format: stun:host:port  or  turn:user:pass@host:port
VITE_ICE_SERVERS=stun:stun.l.google.com:19302

# ----------------------------------------------------------------------------
# Backend TURN configuration (set as Wrangler SECRETS, not here) — OPTIONAL
# but strongly recommended so peers behind symmetric/carrier-grade NAT connect.
# TURN only relays already-encrypted bytes, so end-to-end encryption holds.
#
# Preferred — Cloudflare Calls TURN (short-lived creds minted per request):
#   cd backend && npx wrangler secret put TURN_TOKEN_ID
#                 npx wrangler secret put TURN_API_TOKEN
#
# Alternative — a static TURN server (coturn / Twilio / Metered):
#   npx wrangler secret put TURN_URLS         # e.g. turn:turn.example.com:3478
#   npx wrangler secret put TURN_USERNAME
#   npx wrangler secret put TURN_CREDENTIAL
# ----------------------------------------------------------------------------
